          <Row label="Backup exportieren" onClick={downloadBackup} chevron />
          <Row label="Backup importieren" onClick={() => backupRef.current?.click()} chevron />
          <Row label="Eltern-PIN ändern" onClick={changePin} chevron />
          {msg && <div className="dim" style={{ fontSize: 13.5, lineHeight: 1.45, padding: "8px 2px 14px" }}>{msg}</div>}
          <div className="dim" style={{ fontSize: 13.5, lineHeight: 1.5, marginBottom: 10 }}>
            Setzt Lernstand, XP, Streak und Bestenliste zurück. Zum Bestätigen <b style={{ color: "var(--text)" }}>reset</b> eintippen.
          </div>
          <input className="field" style={{ fontSize: 16, padding: "12px 16px" }} value={resetText} onChange={e => setResetText(e.target.value)} placeholder="reset" autoCapitalize="off" />
          <button className="btn btn-block" disabled={resetText.trim().toLowerCase() !== "reset"}
            onClick={() => {
              if (!requireParentPin("Alles zurücksetzen")) return;
              resetAll();
              window.location.reload();
            }}
            style={{ marginTop: 10, background: resetText.trim().toLowerCase() === "reset" ? "var(--wrong)" : "var(--surface-2)",
              color: resetText.trim().toLowerCase() === "reset" ? "#fff" : "var(--text-dim)" }}>
            Alles zurücksetzen
          </button>
        </Section>

        <div className="dim" style={{ textAlign: "center", fontSize: 12, marginTop: 4 }}>Vokabeltrainer · {languageLabel(state.language)} · {TOTAL_WORDS} Wörter · v2</div>
      </div>
    </div>
  );
}
