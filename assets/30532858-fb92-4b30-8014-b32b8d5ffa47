        <Section title="Darstellung">
          <Row label="Theme" value={curTheme ? curTheme.name : "—"} onClick={onOpenTheme} chevron />
          <Toggle label="Sound-Effekte" sub="Töne bei richtig/falsch" on={tweaks.sound} onToggle={() => setTweak("sound", !tweaks.sound)} />
        </Section>

