  const [showShare, setShowShare] = useS(false);
  const refresh = () => setChildren(listChildren());

  const addChild = () => {
    const name = window.prompt("Name des Kindes");
    if (name === null) return;
    try {
      const next = addChildProfile(name, state.theme);
      setState(next);
      refresh();
    } catch (e) {
      window.alert(e.message || "Kind konnte nicht angelegt werden.");
    }
  };
  const pickChild = (id) => {
    setState(s => switchChild(s, id));
    go("home");
