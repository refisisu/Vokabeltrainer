      </div>

      {/* Child tabs */}
      {children.length > 1 && (
        <div style={{ display: "flex", gap: 8, padding: "4px 18px 6px", overflowX: "auto", scrollbarWidth: "none" }}>
          {children.map((c, i) => (
            <button key={c.id} onClick={() => setSelIdx(i)} style={{ flex: "0 0 auto", padding: "7px 14px", borderRadius: 99, cursor: "pointer",
              border: "1px solid var(--border)", fontWeight: 600, fontSize: 13, fontFamily: "var(--font-ui)",
              background: selIdx === i ? "var(--primary)" : "var(--surface)", color: selIdx === i ? "var(--primary-ink)" : "var(--text-dim)" }}>
              {c.name || "Kind " + (i + 1)}
            </button>
          ))}
        </div>
      )}

      {/* Language tabs */}
      {activeLangs.length > 1 && (
        <div style={{ display: "flex", gap: 8, padding: "4px 18px 6px", overflowX: "auto", scrollbarWidth: "none" }}>
          {activeLangs.map(l => (
            <button key={l.id} onClick={() => setLang(l.id)} style={{ flex: "0 0 auto", padding: "7px 14px", borderRadius: 99, cursor: "pointer",
              border: "1px solid var(--border)", fontWeight: 600, fontSize: 13, fontFamily: "var(--font-ui)",
              background: lang === l.id ? "var(--accent)" : "var(--surface)", color: lang === l.id ? "#fff" : "var(--text-dim)" }}>
              {l.name}
            </button>
          ))}
        </div>
      )}

      <div className="scroll" style={{ padding: "8px 18px 36px", display: "flex", flexDirection: "column", gap: 14 }}>
        {/* Stats row */}
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 10 }}>
          <div className="card" style={{ padding: "14px 8px", textAlign: "center" }}>
            <div className="display" style={{ fontSize: 24, fontWeight: 700 }}>{prog.sessions || 0}</div>
            <div className="dim" style={{ fontSize: 11.5, marginTop: 2 }}>Sessions</div>
          </div>
          <div className="card" style={{ padding: "14px 8px", textAlign: "center" }}>
            <div className="display" style={{ fontSize: 24, fontWeight: 700 }}>{prog.streak || 0}</div>
            <div className="dim" style={{ fontSize: 11.5, marginTop: 2 }}>Tage Streak</div>
          </div>
          <div className="card" style={{ padding: "14px 8px", textAlign: "center" }}>
            <div className="display" style={{ fontSize: 24, fontWeight: 700 }}>{best}%</div>
            <div className="dim" style={{ fontSize: 11.5, marginTop: 2 }}>Bestwert</div>
          </div>
        </div>

        {/* Last active */}
        <div className="card" style={{ padding: "14px 16px", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <span className="dim" style={{ fontSize: 15 }}>Zuletzt gelernt</span>
          <span style={{ fontWeight: 700, fontSize: 15 }}>{relativeDate(prog.last)}</span>
        </div>

        {/* Mastery */}
        <div className="card" style={{ padding: 16 }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: 10 }}>
            <div style={{ fontFamily: "var(--font-display)", fontWeight: 600, fontSize: 17 }}>Lernstand</div>
            <div className="dim" style={{ fontSize: 13 }}>{totalWords} Wörter</div>
          </div>
          <div style={{ display: "flex", height: 12, borderRadius: 99, overflow: "hidden", background: "var(--surface-3)", marginBottom: 12 }}>
            {levels.map((c, i) => c > 0 && (
              <div key={i} style={{ width: (c / (totalWords || 1) * 100) + "%", background: levelCols[i], transition: "width .4s var(--ease)" }} />
            ))}
          </div>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "7px 14px" }}>
            {levelLabels.map((l, i) => (
              <div key={i} style={{ display: "flex", alignItems: "center", gap: 7, fontSize: 13 }}>
                <span style={{ width: 9, height: 9, borderRadius: 3, background: levelCols[i] }} />
                <span className="dim">{l}</span>
                <span style={{ marginLeft: "auto", fontWeight: 700, fontFamily: "var(--font-display)" }}>{levels[i]}</span>
              </div>
            ))}
          </div>
          <div style={{ marginTop: 14 }}>
            <ProgressBar value={mastered} total={totalWords || 1} accent="var(--correct)" label={pctMastered + "% gemeistert"} />
          </div>
        </div>

        {/* Week chart */}
        {history.length > 0 && (
          <div className="card" style={{ padding: 16 }}>
            <WeekChart history={history} />
          </div>
        )}

        {/* Session history */}
        {history.length > 0 && (
          <div>
            <div className="eyebrow" style={{ marginBottom: 10, marginLeft: 2 }}>Letzte Sessions</div>
            <div style={{ display: "grid", gap: 8 }}>
              {history.slice(0, 5).map((h, i) => (
                <div key={i} className="card" style={{ padding: "12px 15px", display: "flex", alignItems: "center", gap: 12 }}>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontWeight: 600, fontSize: 15 }}>
                      {h.score}/{h.total} richtig
                      {h.mode === "test" && <span style={{ fontSize: 11, fontWeight: 700, color: "var(--accent-2)", marginLeft: 6 }}>TEST</span>}
                    </div>
                    <div className="dim" style={{ fontSize: 12.5 }}>{fmtDate(h.date)}</div>
                  </div>
                  <div className="display" style={{ fontSize: 20, fontWeight: 700, color: (h.pct || 0) >= 60 ? "var(--correct)" : "var(--wrong)" }}>{h.pct}%</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Multi-child comparison */}
        {children.length > 1 && (
          <div>
            <div className="eyebrow" style={{ marginBottom: 10, marginLeft: 2 }}>Vergleich</div>
            <div style={{ display: "grid", gap: 8 }}>
              {children.map((c, i) => {
                const cp = c.progress?.[lang] || {};
                const cLevels = cp.levels || [0,0,0,0,0];
                const cTotal = cp.totalWords || 0;
                const cMastered = cLevels[4] || 0;
                const cPct = cTotal ? Math.round(cMastered / cTotal * 100) : 0;
                return (
                  <div key={c.id} className="card" style={{ padding: "13px 15px" }}>
                    <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 8, alignItems: "center" }}>
                      <span style={{ fontWeight: 700, fontFamily: "var(--font-display)", fontSize: 16 }}>{c.name || "Kind " + (i + 1)}</span>
                      <span className="dim" style={{ fontSize: 12.5 }}>{cp.sessions || 0} Sessions · {relativeDate(cp.last)}</span>
                    </div>
                    <ProgressBar value={cMastered} total={cTotal || 1} accent="var(--correct)" label={cPct + "%"} />
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <div className="dim" style={{ textAlign: "center", fontSize: 12, marginTop: 8 }}>
          Momentaufnahme vom {fmtDate(data.ts)} · Vokabeltrainer
        </div>
      </div>
    </div>
  );
}

Object.assign(window, { Onboarding, ThemeSheet, Home, Result, Diagnose, Overview, Leaderboard, ParentDashboard, ParentReadView, Settings });
