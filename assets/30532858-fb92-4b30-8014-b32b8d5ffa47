/* ---------------- SETTINGS ---------------- */
function Settings({ state, setState, go, onOpenTheme, tweaks, setTweak }) {
  const [name, setName] = useS(state.name);
  const [resetText, setResetText] = useS("");
  const csvRef = useR(null);
  const backupRef = useR(null);
  const [msg, setMsg] = useS("");
  const saveName = () => setState(s => ({ ...s, name: name.trim() }));
  const curTheme = THEMES.find(t => t.id === state.theme);
  const requireParentPin = (label) => {
    const pin = window.prompt("Eltern-PIN für " + label);
    if (pin === null) return false;
    if (!verifyParentPin(pin)) {
      setMsg("Eltern-PIN falsch.");
      return false;
    }
    return true;
  };
  const readFile = (file, cb) => {
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => cb(String(reader.result || ""));
    reader.readAsText(file);
  };
  const importCsv = (file) => readFile(file, (text) => {
    try {
      const count = importVocabularyCsv(state.language, text);
      setMsg(count + " Vokabeln für " + languageLabel(state.language) + " importiert.");
      setState(s => ({ ...s }));
    } catch (e) {
      setMsg(e.message || "CSV konnte nicht gelesen werden.");
    }
  });
  const importBackup = (file) => readFile(file, (text) => {
    if (!window.confirm("Backup importieren? Der aktuelle Stand wird überschrieben.")) return;
    if (!requireParentPin("Backup importieren")) return;
    try {
      restoreBackupText(text);
      window.location.reload();
    } catch (e) {
      setMsg(e.message || "Backup konnte nicht gelesen werden.");
    }
  });
  const deleteCurrentVocabulary = () => {
    if (!hasImportedVocabulary(state.language)) {
      setMsg("Für " + languageLabel(state.language) + " ist keine importierte Liste gespeichert.");
      return;
    }
    if (!requireParentPin("Vokabelliste löschen")) return;
    if (!window.confirm("Importierte Vokabelliste für " + languageLabel(state.language) + " löschen?")) return;
    deleteVocabulary(state.language);
    setMsg("Importierte Vokabelliste für " + languageLabel(state.language) + " gelöscht.");
    setState(s => ({ ...s }));
  };
  const changePin = () => {
    if (!requireParentPin("PIN ändern")) return;
    const next = window.prompt("Neuen Eltern-PIN eingeben (4 bis 8 Ziffern)");
    if (next === null) return;
    const again = window.prompt("Neuen Eltern-PIN wiederholen");
    if (again === null) return;
    if (next !== again) {
      setMsg("Die neuen PINs stimmen nicht überein.");
      return;
    }
    try {
      changeParentPin(next);
      setMsg("Eltern-PIN geändert.");
    } catch (e) {
      setMsg(e.message || "PIN konnte nicht geändert werden.");
    }
  };
  return (
    <div style={{ display: "flex", flexDirection: "column", flex: 1, minHeight: 0 }}>
      <TopBar left={<IconBtn name="back" onClick={() => go("home")} label="Zurück" />} title="Einstellungen" right={<span />} />
      <div className="scroll" style={{ padding: "8px 18px 30px", display: "flex", flexDirection: "column", gap: 18 }}>
        <Section title="Profil">
          <label className="dim" style={{ fontSize: 13, fontWeight: 600 }}>Name</label>
          <div style={{ display: "flex", gap: 10, marginTop: 8 }}>
            <input className="field" style={{ fontSize: 16, padding: "12px 16px" }} value={name} maxLength={16} onChange={e => setName(e.target.value)} onBlur={saveName} placeholder="Dein Name" />
          </div>
        </Section>

        <Section title="Kinder">
          <Row label="Eltern-Dashboard" value="PIN" onClick={() => go("parent")} chevron />
          <Row label="Kind hinzufügen" onClick={() => {
            if (!requireParentPin("Kind hinzufügen")) return;
            const childName = window.prompt("Name des Kindes");
            if (childName === null) return;
            try {
              setState(addChildProfile(childName, state.theme));
              setName(childName.trim());
              setMsg("Kinderprofil angelegt.");
            } catch (e) {
              setMsg(e.message || "Kind konnte nicht angelegt werden.");
            }
          }} chevron />
        </Section>

        <Section title="Sprache">
          {LANGUAGES.map(l => (
            <Row key={l.id} label={l.name} value={state.language === l.id ? "Aktiv" : null}
              onClick={() => setState(s => switchLanguage(s, l.id))} chevron />
          ))}
