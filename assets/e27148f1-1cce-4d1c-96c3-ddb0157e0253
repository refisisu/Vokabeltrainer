const LANGUAGES = [
  { id: "en", name: "Englisch", short: "EN" },
  { id: "fr", name: "Französisch", short: "FR" },
];

let ACTIVE_LANGUAGE = "en";
let VOCAB = [];
let TOTAL_WORDS = 0;
let byId = {};

// --- Storage ---
const LS_KEY = "vt_state_v2";
const LEGACY_LS_KEY = "vt_state_v1";
const VOCAB_KEY = (lang) => "vt_vocab_" + lang;
const todayStr = () => new Date().toISOString().slice(0, 10);

function normalize(s) {
  return (s || "").toLowerCase().trim().replace(/\s+/g, " ").replace(/[.!?,]$/, "");
}
function normalizeLang(lang) {
  return LANGUAGES.some(l => l.id === lang) ? lang : "en";
}
function languageLabel(lang = ACTIVE_LANGUAGE) {
  return LANGUAGES.find(l => l.id === normalizeLang(lang))?.name || "Englisch";
}
function languageShort(lang = ACTIVE_LANGUAGE) {
  return LANGUAGES.find(l => l.id === normalizeLang(lang))?.short || "EN";
}
function emptyProgress() {
  return {
    xp: 0,
    streak: 0,
    lastSessionDate: null,
    leitner: {},          // id -> { level, correct, wrong, lastSeen }
    history: [],          // { date, score, total, pct, mode }
    sessionsCount: 0,
  };
}
function defaultStore() {
  return {
    version: 3,
    activeLanguage: "en",
    activeChildId: "child-1",
    profile: { onboarded: false, name: "", theme: "city" },
    settings: { parentPin: "1111" },
    progress: { en: emptyProgress(), fr: emptyProgress() },
    children: {},
  };
}
function createChild(name = "", theme = "city") {
  const id = "child-" + Date.now().toString(36) + "-" + Math.random().toString(36).slice(2, 6);
  return {
    id,
    profile: { onboarded: true, name: String(name || "").trim(), theme: theme || "city" },
    progress: { en: emptyProgress(), fr: emptyProgress() },
  };
}
function normalizeChild(raw, fallbackId = "child-1") {
  return {
    id: raw?.id || fallbackId,
    profile: { onboarded: !!raw?.profile?.onboarded, name: raw?.profile?.name || "", theme: raw?.profile?.theme || "city" },
    progress: {
      en: { ...emptyProgress(), ...(raw?.progress?.en || {}) },
      fr: { ...emptyProgress(), ...(raw?.progress?.fr || {}) },
    },
  };
}
function migrateChildren(store) {
  const sourceChildren = store.children && typeof store.children === "object" ? store.children : {};
  const children = {};
  Object.keys(sourceChildren).forEach(id => { children[id] = normalizeChild(sourceChildren[id], id); });
  if (!Object.keys(children).length) {
    const id = store.activeChildId || "child-1";
    children[id] = normalizeChild({
      id,
      profile: store.profile || defaultStore().profile,
      progress: store.progress || defaultStore().progress,
    }, id);
  }
  let activeChildId = store.activeChildId && children[store.activeChildId] ? store.activeChildId : Object.keys(children)[0];
  return { children, activeChildId };
}
function composeState(store, lang) {
  const active = normalizeLang(lang || store.activeLanguage);
  const { children, activeChildId } = migrateChildren(store);
  const child = children[activeChildId] || normalizeChild(null, activeChildId);
  return {
    childId: activeChildId,
    ...child.profile,
    ...emptyProgress(),
    ...(child.progress?.[active] || {}),
    language: active,
  };
}
function splitState(s) {
  const { childId, onboarded, name, theme, language, xp, streak, lastSessionDate, leitner, history, sessionsCount } = s;
  return {
    childId: childId || "child-1",
    profile: { onboarded: !!onboarded, name: name || "", theme: theme || "city" },
    language: normalizeLang(language || ACTIVE_LANGUAGE),
    progress: { xp, streak, lastSessionDate, leitner: leitner || {}, history: history || [], sessionsCount: sessionsCount || 0 },
  };
}
function enrichVocabulary(lang, rows) {
  return rows.map((w, i) => {
    const en = String(w.en || w.term || "").trim();
    const de = String(w.de || "").trim();
    const example = String(w.example || "").trim();
    const note = String(w.note || "").trim();
    const pronunciation = String(w.pronunciation || "").trim();
    const id = String(w.id || (lang + "-" + normalize(en) + "-" + i)).replace(/\s+/g, "-");
    return {
      id,
      en,
      de,
      language: lang,
      example: example || (lang === "en" ? (EXAMPLES[en.toLowerCase()] || null) : null),
      note: note || null,
      pronunciation: pronunciation || null,
    };
  }).filter(w => w.en && w.de);
}
function loadVocabulary(lang = ACTIVE_LANGUAGE) {
  const active = normalizeLang(lang);
  try {
    const raw = localStorage.getItem(VOCAB_KEY(active));
    if (raw) return enrichVocabulary(active, JSON.parse(raw));
  } catch (e) {}
  return [];
}
function refreshVocabulary(lang = ACTIVE_LANGUAGE) {
  ACTIVE_LANGUAGE = normalizeLang(lang);
  VOCAB = loadVocabulary(ACTIVE_LANGUAGE);
  TOTAL_WORDS = VOCAB.length;
  byId = Object.fromEntries(VOCAB.map(w => [w.id, w]));
  Object.assign(window, { VOCAB, TOTAL_WORDS, byId });
}
function setActiveLanguage(lang) {
  ACTIVE_LANGUAGE = normalizeLang(lang);
  refreshVocabulary(ACTIVE_LANGUAGE);
  return ACTIVE_LANGUAGE;
}
function defaultState(lang = ACTIVE_LANGUAGE) {
  return composeState(defaultStore(), normalizeLang(lang));
}
function readStore() {
  const store = defaultStore();
  try {
    const raw = localStorage.getItem(LS_KEY);
    if (raw) {
      const parsed = JSON.parse(raw);
      const merged = { ...store, ...parsed };
      const migrated = migrateChildren(merged);
      return {
        ...store,
        ...parsed,
        settings: { ...store.settings, ...(parsed.settings || {}) },
        children: migrated.children,
        activeChildId: migrated.activeChildId,
        activeLanguage: normalizeLang(parsed.activeLanguage),
      };
    }
    const legacy = localStorage.getItem(LEGACY_LS_KEY);
    if (legacy) {
      const old = { ...defaultState("en"), ...JSON.parse(legacy), language: "en" };
      const parts = splitState(old);
      const child = normalizeChild({ id: "child-1", profile: parts.profile, progress: { en: parts.progress } }, "child-1");
      return {
        ...store,
        activeLanguage: "en",
        activeChildId: child.id,
        children: { [child.id]: child },
      };
    }
  } catch (e) {}
  return store;
}

function loadState() {
  try {
    const store = readStore();
    setActiveLanguage(store.activeLanguage);
    return composeState(store, ACTIVE_LANGUAGE);
  } catch (e) {
    return defaultState();
  }
}
function saveState(s) {
  try {
    const store = readStore();
    const parts = splitState(s);
    store.activeLanguage = parts.language;
    const child = store.children[parts.childId] || normalizeChild({ id: parts.childId, profile: parts.profile }, parts.childId);
    child.profile = parts.profile;
    child.progress = { ...child.progress, [parts.language]: parts.progress };
    store.children = { ...store.children, [parts.childId]: child };
    store.activeChildId = parts.childId;
    localStorage.setItem(LS_KEY, JSON.stringify(store));
  } catch (e) {}
}
function switchLanguage(currentState, nextLang) {
  saveState(currentState);
  const store = readStore();
  store.activeLanguage = normalizeLang(nextLang);
  localStorage.setItem(LS_KEY, JSON.stringify(store));
  setActiveLanguage(store.activeLanguage);
  return composeState(store, store.activeLanguage);
}
function listChildren() {
  const store = readStore();
  const { children } = migrateChildren(store);
  return Object.values(children);
}
function addChildProfile(name, theme = "city") {
  const cleanName = String(name || "").trim();
  if (!cleanName) throw new Error("Bitte einen Namen eingeben.");
  const store = readStore();
  const child = createChild(cleanName, theme);
  store.children = { ...store.children, [child.id]: child };
  store.activeChildId = child.id;
  localStorage.setItem(LS_KEY, JSON.stringify(store));
  return composeState(store, store.activeLanguage);
}
function switchChild(currentState, childId) {
  saveState(currentState);
  const store = readStore();
  if (!store.children[childId]) return currentState;
  store.activeChildId = childId;
  localStorage.setItem(LS_KEY, JSON.stringify(store));
  return composeState(store, store.activeLanguage);
}
function renameChild(childId, name) {
  const cleanName = String(name || "").trim();
  const store = readStore();
  if (!store.children[childId] || !cleanName) return;
  store.children[childId].profile = { ...store.children[childId].profile, name: cleanName };
  localStorage.setItem(LS_KEY, JSON.stringify(store));
}
function progressForChild(child, lang = ACTIVE_LANGUAGE) {
  return { ...emptyProgress(), ...(child?.progress?.[normalizeLang(lang)] || {}) };
}
function childSummary(child, lang = ACTIVE_LANGUAGE) {
  const progress = progressForChild(child, lang);
  const words = loadVocabulary(lang);
  const totalWords = words.length;
  const levels = [0, 0, 0, 0, 0];
  words.forEach(w => {
    const lvl = progress.leitner?.[w.id]?.level || 1;
    levels[Math.max(1, Math.min(5, lvl)) - 1] += 1;
  });
  const attempts = Object.values(progress.leitner || {}).reduce((sum, rec) => sum + (rec.correct || 0) + (rec.wrong || 0), 0);
  const mastered = levels[4] || 0;
  const best = progress.history.length ? Math.max(...progress.history.map(h => h.pct || 0)) : 0;
  const last = progress.history[0] || null;
  const pctMastered = totalWords ? Math.round(mastered / totalWords * 100) : 0;
  return { child, lang: normalizeLang(lang), progress, totalWords, levels, attempts, mastered, pctMastered, best, last };
}
function resetAll() {
  try {
    localStorage.removeItem(LS_KEY);
    localStorage.removeItem(LEGACY_LS_KEY);
    localStorage.removeItem(VOCAB_KEY("en"));
    localStorage.removeItem(VOCAB_KEY("fr"));
  } catch (e) {}
}
function getParentPin() {
  return String(readStore().settings?.parentPin || "1111");
}
function verifyParentPin(pin) {
  return String(pin || "") === getParentPin();
}
function changeParentPin(nextPin) {
  const clean = String(nextPin || "").trim();
  if (!/^\d{4,8}$/.test(clean)) throw new Error("Der PIN muss aus 4 bis 8 Ziffern bestehen.");
  const store = readStore();
  store.settings = { ...(store.settings || {}), parentPin: clean };
  localStorage.setItem(LS_KEY, JSON.stringify(store));
}
function hasImportedVocabulary(lang = ACTIVE_LANGUAGE) {
  try { return !!localStorage.getItem(VOCAB_KEY(normalizeLang(lang))); } catch (e) { return false; }
}
function deleteVocabulary(lang = ACTIVE_LANGUAGE) {
  const active = normalizeLang(lang);
  localStorage.removeItem(VOCAB_KEY(active));
  if (active === ACTIVE_LANGUAGE) refreshVocabulary(active);
}

function parseCsv(text) {
  const delimiter = (text.split("\n")[0].match(/;/g) || []).length > (text.split("\n")[0].match(/,/g) || []).length ? ";" : ",";
  const rows = [];
  let row = [], cell = "", quoted = false;
  for (let i = 0; i < text.length; i++) {
    const ch = text[i], next = text[i + 1];
    if (ch === '"' && quoted && next === '"') { cell += '"'; i++; continue; }
    if (ch === '"') { quoted = !quoted; continue; }
    if (ch === delimiter && !quoted) { row.push(cell); cell = ""; continue; }
    if ((ch === "\n" || ch === "\r") && !quoted) {
      if (ch === "\r" && next === "\n") i++;
      row.push(cell); rows.push(row); row = []; cell = ""; continue;
    }
    cell += ch;
  }
  row.push(cell); rows.push(row);
  const clean = rows.map(r => r.map(c => c.trim())).filter(r => r.some(Boolean));
  const first = clean[0] || [];
  const headerKey = (s) => normalize(s).replace(/ä/g, "ae").replace(/ö/g, "oe").replace(/ü/g, "ue").replace(/ß/g, "ss");
  const headers = first.map(headerKey);
  const hasHeader = /^(fremdwort|term|wort|word|vokabel|anglais|franzoesisch|franzoesisch|englisch|english|french)$/.test(headers[0] || "")
    || /^(uebersetzung|deutsch|german)$/.test(headers[1] || "");
  const body = hasHeader ? clean.slice(1) : clean;
  const idx = (names, fallback) => {
    if (!hasHeader) return fallback;
    const found = headers.findIndex(h => names.includes(h));
    return found >= 0 ? found : fallback;
  };
  const termIdx = idx(["fremdwort", "term", "wort", "word", "vokabel", "englisch", "english", "franzoesisch", "french"], 0);
  const deIdx = idx(["uebersetzung", "deutsch", "german"], 1);
  const exampleIdx = idx(["beispiel", "beispielsatz", "example", "sentence", "satz"], 2);
  const noteIdx = idx(["hinweis", "info", "notiz", "note", "erklaerung", "erklaerung"], 3);
  const pronunciationIdx = idx(["aussprache", "lautschrift", "pronunciation", "ipa"], 4);
  const seen = new Set();
  return body.map((r, i) => ({
    en: r[termIdx],
    de: r[deIdx],
    example: r[exampleIdx],
    note: r[noteIdx],
    pronunciation: r[pronunciationIdx],
    id: "csv-" + i
  }))
    .filter(w => {
      const key = normalize(w.en);
      if (!w.en || !w.de || seen.has(key)) return false;
      seen.add(key);
      return true;
    });
}
function importVocabularyCsv(lang, text) {
  const active = normalizeLang(lang);
  const rows = parseCsv(text);
  if (!rows.length) throw new Error("Keine gültigen Vokabeln gefunden.");
  localStorage.setItem(VOCAB_KEY(active), JSON.stringify(rows));
  if (active === ACTIVE_LANGUAGE) refreshVocabulary(active);
  return rows.length;
}
function exportBackup() {
  return {
    version: 3,
    exportedAt: new Date().toISOString(),
    state: readStore(),
    vocab: {
      en: JSON.parse(localStorage.getItem(VOCAB_KEY("en")) || "null"),
      fr: JSON.parse(localStorage.getItem(VOCAB_KEY("fr")) || "null"),
    },
  };
}
function downloadBackup() {
  const stamp = todayStr();
  const blob = new Blob([JSON.stringify(exportBackup(), null, 2)], { type: "application/json" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "vokabeltrainer-backup-" + stamp + ".json";
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}
function restoreBackupText(text) {
  const data = JSON.parse(text);
  if (!data || ![2, 3].includes(data.version) || !data.state) throw new Error("Backup-Format nicht erkannt.");
  const restored = { ...defaultStore(), ...data.state };
  const migrated = migrateChildren(restored);
  restored.children = migrated.children;
  restored.activeChildId = migrated.activeChildId;
  localStorage.setItem(LS_KEY, JSON.stringify(restored));
  if (data.vocab?.en) localStorage.setItem(VOCAB_KEY("en"), JSON.stringify(data.vocab.en));
  if (data.vocab?.fr) localStorage.setItem(VOCAB_KEY("fr"), JSON.stringify(data.vocab.fr));
}

// --- Leitner helpers ---
function getLevel(state, id) {
  return state.leitner[id]?.level || 1;
}
function ensureLeitner(state, id) {
  if (!state.leitner[id]) state.leitner[id] = { level: 1, correct: 0, wrong: 0, lastSeen: null };
  return state.leitner[id];
}
// Words due this session by Leitner cadence (level N seen every 2^(N-1) sessions).
function dueWords(state) {
  const s = state.sessionsCount;
  return VOCAB.filter(w => {
    const lvl = getLevel(state, w.id);
    if (lvl >= 5) return false;            // mastered -> only test mode
    const cadence = Math.pow(2, lvl - 1);  // 1,2,4,8
    return s % cadence === 0;
  });
}
// Mastery distribution across levels 1..5
function masteryDistribution(state) {
  const dist = [0, 0, 0, 0, 0];
  for (const w of VOCAB) dist[getLevel(state, w.id) - 1]++;
  return dist; // index0 = level1
}
function accuracy(state, id) {
  const r = state.leitner[id];
  if (!r || (r.correct + r.wrong) === 0) return null;
  return r.correct / (r.correct + r.wrong);
}

// --- Question building ---
function pick(arr, n) {
  const c = [...arr];
  for (let i = c.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [c[i], c[j]] = [c[j], c[i]];
  }
  return c.slice(0, n);
}
function distractors(word, field, n) {
  // other words' value in `field` (en/de), excluding same value
  const pool = VOCAB.filter(w => w.id !== word.id && w[field] !== word[field]);
  return pick(pool, n).map(w => w[field]);
}

// Build one question object for a word, given allowed types.
function makeQuestion(word, types) {
  const usable = types.filter(t => t !== "match"); // match handled in groups
  let avail = [...usable];
  if (!word.example) avail = avail.filter(t => t !== "cloze");
  if (avail.length === 0) avail = ["mc"];
  const type = pick(avail, 1)[0];

  if (type === "mc") {
    // randomly EN->DE or DE->EN
    const dir = Math.random() < 0.5 ? "en2de" : "de2en";
    const prompt = dir === "en2de" ? word.en : word.de;
    const answerField = dir === "en2de" ? "de" : "en";
    const correct = word[answerField];
    const opts = pick([correct, ...distractors(word, answerField, 3)], 4);
    return { kind: "mc", word, dir, prompt, correct, options: opts };
  }
  if (type === "type") {
    // German given, type the English
    return { kind: "type", word, prompt: word.de, correct: word.en };
  }
  if (type === "cloze") {
    const en = word.en;
    // blank the english word (case-insensitive, first occurrence)
    const re = new RegExp(en.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "i");
    const sentence = word.example.replace(re, "_____");
    return { kind: "cloze", word, sentence, hint: word.de, correct: en };
  }
  return { kind: "mc", word, dir: "en2de", prompt: word.en, correct: word.de,
           options: pick([word.de, ...distractors(word, "de", 3)], 4) };
}

// Build a full session queue (mix of single Qs + one match group).
function buildSession(state, types, max = 15) {
  let due = dueWords(state);
  if (due.length < 6) {
    // top up with lowest-level words
    const extra = [...VOCAB].sort((a, b) => getLevel(state, a.id) - getLevel(state, b.id));
    const have = new Set(due.map(w => w.id));
    for (const w of extra) { if (!have.has(w.id)) { due.push(w); have.add(w.id); } if (due.length >= max + 6) break; }
  }
  // prioritize lower levels
  due.sort((a, b) => getLevel(state, a.id) - getLevel(state, b.id) || Math.random() - 0.5);
  const chosen = due.slice(0, max);

  const queue = [];
  const wantMatch = types.includes("match") && chosen.length >= 6;
  let matchPool = [];
  if (wantMatch) matchPool = chosen.slice(0, 6);
  const singleWords = wantMatch ? chosen.slice(6) : chosen;

  for (const w of singleWords) queue.push(makeQuestion(w, types));

  if (wantMatch) {
    const group = { kind: "match", pairs: matchPool.map(w => ({ id: w.id, en: w.en, de: w.de })) };
    // insert match round in the middle
    const mid = Math.floor(queue.length / 2);
    queue.splice(mid, 0, group);
  }
  return queue.slice(0, max);
}

// Test mode: every word once, MC only, no leitner change.
function buildTest(state) {
  const all = pick(VOCAB, VOCAB.length);
  return all.map(w => {
    const dir = "en2de";
    return { kind: "mc", word: w, dir, prompt: w.en, correct: w.de,
             options: pick([w.de, ...distractors(w, "de", 3)], 4), test: true };
  });
}

// Apply an answer result to state (mutates a clone in caller). Returns xp gained.
function applyResult(state, wordId, outcome) {
  // outcome: 'first' | 'second' | 'wrong'
  const rec = ensureLeitner(state, wordId);
  rec.lastSeen = todayStr();
  let xp = 0;
  if (outcome === "first") { rec.level = Math.min(5, rec.level + 1); rec.correct++; xp = 10; }
  else if (outcome === "second") { rec.correct++; xp = 5; } // no level change
  else { rec.level = 1; rec.wrong++; xp = 0; }
  return xp;
}

function finishSession(state, score, total, mode) {
  const today = todayStr();
  if (mode !== "test") {
    // streak
    if (state.lastSessionDate !== today) {
      const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
      if (state.lastSessionDate === yesterday) state.streak += 1;
      else state.streak = 1;
      state.lastSessionDate = today;
    }
    state.sessionsCount += 1;
  }
  const pct = total ? Math.round((score / total) * 100) : 0;
  state.history.unshift({ date: today, ts: Date.now(), score, total, pct, mode });
  state.history = state.history.slice(0, 30);
}

function weeklyActivity(progress) {
  const days = [];
  const today = new Date();
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    const dateStr = d.toISOString().slice(0, 10);
    const count = (progress.history || []).filter(h => h.date === dateStr && h.mode !== "test").length;
    days.push({ date: dateStr, count, label: d.toLocaleDateString("de-DE", { weekday: "short" }).slice(0, 2) });
  }
  return days;
}

function relativeDate(dateStr) {
  if (!dateStr) return "Nie";
  try {
    const diffDays = Math.round((Date.now() - new Date(dateStr + "T12:00:00")) / 86400000);
    if (diffDays === 0) return "Heute";
    if (diffDays === 1) return "Gestern";
    if (diffDays < 7) return "vor " + diffDays + " Tagen";
    if (diffDays < 30) return "vor " + Math.round(diffDays / 7) + " Wochen";
    return "vor " + Math.round(diffDays / 30) + " Mon.";
  } catch (e) { return dateStr; }
}

function exportParentSnapshot() {
  const store = readStore();
  const { children } = migrateChildren(store);
  const langs = ["en", "fr"];
  return {
    v: 1,
    ts: todayStr(),
    children: Object.values(children).map(child => {
      const progress = {};
      langs.forEach(lang => {
        const prog = { ...emptyProgress(), ...(child.progress?.[lang] || {}) };
        const words = loadVocabulary(lang);
        if (prog.sessionsCount === 0 && !words.length) return;
        const levels = [0, 0, 0, 0, 0];
        words.forEach(w => { levels[Math.max(0, Math.min(4, (prog.leitner?.[w.id]?.level || 1) - 1))]++; });
        progress[lang] = {
          xp: prog.xp || 0,
          streak: prog.streak || 0,
          sessions: prog.sessionsCount || 0,
          last: prog.lastSessionDate || null,
          levels,
          totalWords: words.length,
          history: (prog.history || []).slice(0, 7).map(h => ({
            d: h.date, s: h.score, t: h.total, p: h.pct, m: h.mode === "test" ? 1 : 0
          }))
        };
      });
      if (!Object.keys(progress).length) {
        const lang = store.activeLanguage || "en";
        progress[lang] = { xp: 0, streak: 0, sessions: 0, last: null, levels: [0,0,0,0,0], totalWords: 0, history: [] };
      }
      return { id: child.id, name: child.profile.name || "Kind", progress };
    })
  };
}

function makeParentShareUrl() {
  try {
    const b64 = btoa(unescape(encodeURIComponent(JSON.stringify(exportParentSnapshot()))));
    return window.location.origin + window.location.pathname.replace(/\/+$/, "") + "#pv=" + b64;
  } catch (e) { return null; }
}

