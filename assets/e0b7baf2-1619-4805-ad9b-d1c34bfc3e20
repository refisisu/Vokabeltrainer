// vt-app.jsx — root: state machine, routing, theme, tweaks.
const { useState: useA, useEffect: useAE, useRef: useARef } = React;

const ACTIVE_TYPES = ["mc", "type", "cloze", "match"];

const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
  "feedbackStyle": "konfetti",
  "mascotReact": true,
  "shake": true,
  "sound": false
}/*EDITMODE-END*/;

function clone(s) { return JSON.parse(JSON.stringify(s)); }

/* ── Offline-Session-Queue ── */
function queueSessionOffline(data) {
  try {
    const pending = JSON.parse(localStorage.getItem("vt_pending_sessions") || "[]");
    pending.push({ ...data, queued_at: new Date().toISOString() });
    localStorage.setItem("vt_pending_sessions", JSON.stringify(pending));
  } catch (e) {}
}

async function flushPendingSessions(userId) {
  try {
    const raw = localStorage.getItem("vt_pending_sessions");
    if (!raw) return;
    const pending = JSON.parse(raw);
    if (!pending.length) return;
    localStorage.removeItem("vt_pending_sessions");
    for (const s of pending) {
      const { queued_at, ...data } = s;
      await window._sb.from("voc_sessions").insert({ user_id: userId, ...data });
    }
  } catch (e) {}
}

function App() {
  const [session, setSession] = useA(null);
  const [vocUser, setVocUser] = useA(null);
  const [authLoading, setAuthLoading] = useA(true);
  const [inClass, setInClass] = useA(false);
  const [joinMsg, setJoinMsg] = useA(null);
  const [isOnline, setIsOnline] = useA(navigator.onLine);

  // Online/Offline-Erkennung + Flush der Queue wenn wieder online
  useAE(() => {
    const goOnline = () => setIsOnline(true);
    const goOffline = () => setIsOnline(false);
    window.addEventListener("online", goOnline);
    window.addEventListener("offline", goOffline);
    return () => {
      window.removeEventListener("online", goOnline);
      window.removeEventListener("offline", goOffline);
    };
  }, []);

  useAE(() => {
    if (isOnline && session) flushPendingSessions(session.user.id);
  }, [isOnline, session]);

  // Auth: session bootstrap + listener
  useAE(() => {
    window._sb.auth.getSession().then(({ data: { session } }) => {
      setSession(session);
      if (session) loadVocUser(session.user.id);
      else setAuthLoading(false);
    });
    const { data: { subscription } } = window._sb.auth.onAuthStateChange(async (_event, session) => {
      setSession(session);
      if (session) {
        await loadVocUser(session.user.id);
        const code = sessionStorage.getItem("vt_join");
        if (code) {
          sessionStorage.removeItem("vt_join");
          const { className, error } = await joinClass(code, session.user.id);
          if (!error) setInClass(true);
          setJoinMsg(error ? "Klasse nicht gefunden." : `Du bist jetzt in: ${className} 🎉`);
        }
      } else {
        setVocUser(null);
        setInClass(false);
        setAuthLoading(false);
      }
    });
    return () => subscription.unsubscribe();
  }, []);

  async function loadVocUser(userId) {
    const [{ data: user }, { data: membership }] = await Promise.all([
      window._sb.from("voc_users").select("*").eq("id", userId).maybeSingle(),
      window._sb.from("voc_class_members").select("id").eq("user_id", userId).limit(1).maybeSingle(),
    ]);
    setVocUser(user || null);
    setInClass(!!membership);
    setAuthLoading(false);
  }

  const joinCode = new URLSearchParams(window.location.search).get("join");

  const [state, setState] = useA(loadState);
  const [screen, setScreen] = useA(() => (loadState().onboarded ? "home" : "onboarding"));
  const [queue, setQueue] = useA(null);
  const [mode, setMode] = useA("session");
  const [lastResult, setLastResult] = useA(null);
  const [themeSheet, setThemeSheet] = useA(false);
  const [tweaks, setTweak] = useTweaks(TWEAK_DEFAULTS);

  useStarfield();

  window.__vtTheme = state.onboarded ? state.theme : "city";

  useAE(() => { saveState(state); }, [state]);
  useAE(() => { if (state.onboarded) document.body.className = "theme-" + state.theme; }, [state.theme, state.onboarded]);

  const go = (target) => {
    if (target === "session") {
      setQueue(buildSession(state, ACTIVE_TYPES, 15)); setMode("session"); setScreen("quiz");
    } else if (target === "test") {
      setQueue(buildTest(state)); setMode("test"); setScreen("quiz");
    } else if (target === "parent") {
      const pin = window.prompt("Eltern-PIN");
      if (pin === null) return;
      if (!verifyParentPin(pin)) {
        window.alert("Eltern-PIN falsch.");
        return;
      }
      setScreen("parent");
    } else {
      setScreen(target);
    }
    const sc = document.querySelector(".scroll"); // reset scroll on nav
  };

  const onFinish = (result) => {
    setState(prev => {
      const s = clone(prev);
      if (mode !== "test") {
        result.leitnerUpdates.forEach(u => applyResult(s, u.id, u.outcome));
        s.xp += result.xp;
      }
      finishSession(s, result.score, result.total, mode === "test" ? "test" : "session");
      return s;
    });
    setLastResult(result);
    setScreen(mode === "test" ? "diagnose" : "result");

    // Nur speichern wenn: eingeloggt, normaler Modus, Schüler in einer Klasse (oder Lehrer)
    const shouldPersist = !SKIP_AUTH && session && vocUser && mode !== "test"
      && (vocUser.role === "teacher" || inClass);

    if (shouldPersist) {
      const listId = (() => { try { return JSON.parse(localStorage.getItem("vt_active_list"))?.id || null; } catch(e) { return null; } })();
      const sessionData = { list_id: listId, score: result.score, total: result.total, xp: result.xp };

      if (!navigator.onLine) {
        queueSessionOffline(sessionData);
      } else {
        window._sb.from("voc_sessions").insert({ user_id: session.user.id, ...sessionData }).then(() => {});
      }
    }
  };

  const onboardDone = ({ name, theme, language }) => {
    setActiveLanguage(language);
    setState(s => ({ ...s, onboarded: true, name, theme, language }));
    document.body.className = "theme-" + theme;
    setScreen("home");
  };

  const SKIP_AUTH = false;

  if (!SKIP_AUTH) {
    if (authLoading) return (
      <div style={{ flex: 1, display: "flex", alignItems: "center", justifyContent: "center" }}>
        <div className="dim" style={{ fontSize: 15 }}>…</div>
      </div>
    );
    if (!session) return <AuthScreen joinCode={joinCode} />;
    if (!vocUser) return <VocSetup session={session} onDone={(u) => { setVocUser(u); }} />;
  }

  let view = null;
  if (screen === "onboarding") view = <Onboarding onDone={onboardDone} />;
  else if (screen === "home") {
    if (!SKIP_AUTH && vocUser?.role === "teacher") {
      view = <TeacherDashboard session={session} go={go} />;
    } else if (!SKIP_AUTH && vocUser?.role === "student" && TOTAL_WORDS === 0) {
      view = <StudentListPicker session={session} go={go} inClass={inClass} />;
    } else {
      view = <Home state={state} go={go} onOpenTheme={() => setThemeSheet(true)} vocUser={vocUser} />;
    }
  }
  else if (screen === "student-lists") view = <StudentListPicker session={session} go={go} inClass={inClass} />;
  else if (screen === "teacher") view = <TeacherDashboard session={session} go={go} />;
  else if (screen === "quiz") view = <Quiz queue={queue} mode={mode} tweaks={tweaks} onFinish={onFinish} onExit={() => go("home")} />;
  else if (screen === "result") view = <Result result={lastResult} mode={mode} state={state} go={go} tweaks={tweaks} />;
  else if (screen === "diagnose") view = <Diagnose result={lastResult} go={go} tweaks={tweaks} />;
  else if (screen === "overview") view = <Overview state={state} go={go} />;
  else if (screen === "leaderboard") view = <Leaderboard state={state} go={go} />;
  else if (screen === "parent") view = <ParentDashboard state={state} setState={setState} go={go} />;
  else if (screen === "settings") view = <Settings state={state} setState={setState} go={go} onOpenTheme={() => setThemeSheet(true)} tweaks={tweaks} setTweak={setTweak} />;

  return (
    <React.Fragment>
      {/* Offline-Banner */}
      {!isOnline && (
        <div style={{ position: "absolute", top: 0, left: 0, right: 0, zIndex: 60,
          background: "var(--surface-2)", color: "var(--text-dim)", fontSize: 13, fontWeight: 600,
          textAlign: "center", padding: "6px 16px", borderBottom: "1px solid var(--border)" }}>
          Offline – Lernfortschritte werden gespeichert und später synchronisiert
        </div>
      )}
      {joinMsg && (
        <div onClick={() => setJoinMsg(null)}
          style={{ position: "absolute", top: isOnline ? 16 : 42, left: 16, right: 16, zIndex: 50,
            background: "var(--correct-soft)", color: "var(--correct)", borderRadius: "var(--r-md)",
            padding: "12px 16px", fontSize: 15, fontWeight: 600, textAlign: "center", cursor: "pointer" }}>
          {joinMsg}
        </div>
      )}
      {view}
      {themeSheet && <ThemeSheet current={state.theme} onClose={() => setThemeSheet(false)}
        onPick={(id) => { setState(s => ({ ...s, theme: id })); setThemeSheet(false); }} />}

      <TweaksPanel title="Tweaks">
        <TweakSection label="Antwort-Feedback" />
        <TweakRadio label="Belohnung" value={tweaks.feedbackStyle}
          options={["konfetti", "dezent", "aus"]} onChange={v => setTweak("feedbackStyle", v)} />
        <TweakToggle label="Voki reagiert" value={tweaks.mascotReact} onChange={v => setTweak("mascotReact", v)} />
        <TweakToggle label="Wackeln bei Fehler" value={tweaks.shake} onChange={v => setTweak("shake", v)} />
        <TweakToggle label="Sound-Effekte" value={tweaks.sound} onChange={v => setTweak("sound", v)} />
      </TweaksPanel>
    </React.Fragment>
  );
}

// Parent view: render read-only view if URL contains #pv= snapshot
(function () {
  let pvData = null;
  try {
    const hash = window.location.hash;
    if (hash.startsWith("#pv=")) {
      pvData = JSON.parse(decodeURIComponent(escape(atob(hash.slice(4)))));
    }
  } catch (e) {}
  const root = ReactDOM.createRoot(document.getElementById("root"));
  root.render(pvData ? <ParentReadView data={pvData} /> : <App />);
})();
